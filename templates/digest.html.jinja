<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0f172a">
  <title>Morning Brief — {{ date_display }}</title>
  <style>
    :root {
      --bg: #0f172a;
      --surface: #1e293b;
      --border: #334155;
      --text: #e2e8f0;
      --muted: #94a3b8;
      --accent: #38bdf8;
      --tag-cloud: #1e40af;
      --tag-infra: #065f46;
      --tag-ai: #581c87;
      --tag-aus: #7c2d12;
      --tag-news: #374151;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 16px;
      line-height: 1.6;
      max-width: 680px;
      margin: 0 auto;
      padding: 0 1rem 3rem;
    }

    /* ── Header ── */
    header {
      padding: 1.5rem 0 1rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.25rem;
    }
    .brief-title {
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .brief-meta {
      display: flex;
      gap: 1rem;
      margin-top: 0.3rem;
      font-size: 0.85rem;
      color: var(--muted);
    }

    /* ── Podcast player ── */
    .podcast-player {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.85rem 1rem;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .podcast-label {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--accent);
      white-space: nowrap;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .podcast-player audio {
      flex: 1;
      min-width: 0;
      height: 36px;
    }

    /* ── Source group ── */
    .source-group {
      border-left: 3px solid var(--accent);
      border-radius: 8px;
      margin-bottom: 1rem;
      background: var(--surface);
    }
    .source-group > summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.75rem 1rem;
      font-weight: 700;
      font-size: 0.95rem;
      user-select: none;
      border-radius: 8px 8px 0 0;
      color: #fff;
    }
    .source-group > summary::-webkit-details-marker { display: none; }
    .source-group > summary::after {
      content: '\25BE';
      margin-left: auto;
      color: var(--muted);
      transition: transform 0.2s;
    }
    .source-group:not([open]) > summary::after {
      transform: rotate(-90deg);
    }
    .source-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      flex-shrink: 0;
    }
    .article-count {
      font-size: 0.7rem;
      font-weight: 400;
      color: var(--muted);
      background: rgba(255,255,255,0.06);
      padding: 0.1rem 0.5rem;
      border-radius: 10px;
    }
    .source-group-body {
      padding: 0 1rem 0.75rem;
    }

    /* ── Item card ── */
    .item {
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      transition: opacity 0.2s;
    }
    .item:last-child { border-bottom: none; }
    .item.is-read { opacity: 0.4; }
    .item.is-read .item-headline a { text-decoration: line-through; }

    .item-content { flex: 1; }

    .item-headline {
      font-size: 1.05rem;
      font-weight: 600;
      line-height: 1.4;
      margin-bottom: 0.35rem;
    }
    .item-headline a {
      color: var(--text);
      text-decoration: none;
    }
    .item-headline a:hover { color: var(--accent); }

    .mark-read-btn {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.2rem 0.5rem;
      font-size: 0.7rem;
      color: var(--muted);
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
      margin-top: 0.15rem;
    }
    .mark-read-btn:hover { border-color: var(--accent); color: var(--accent); }
    .item.is-read .mark-read-btn { color: #22c55e; border-color: #22c55e; }

    .one-liner {
      font-size: 0.9rem;
      color: var(--muted);
      margin-bottom: 0.5rem;
      line-height: 1.5;
    }
    .item-footer {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .score-pill {
      font-size: 0.7rem;
      color: var(--muted);
      opacity: 0.6;
    }
    .reason {
      font-size: 0.75rem;
      color: var(--muted);
      opacity: 0.7;
      font-style: italic;
    }

    /* ── Sync bar ── */
    .sync-bar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.25rem;
    }
    .sync-bar button {
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.3rem 0.7rem;
      font-size: 0.75rem;
      color: var(--muted);
      cursor: pointer;
    }
    .sync-bar button:hover { border-color: var(--accent); color: var(--accent); }
    .sync-status {
      font-size: 0.7rem;
      color: var(--muted);
      margin-left: auto;
    }
    .sync-status.ok { color: #22c55e; }
    .sync-status.err { color: #ef4444; }
    .sync-dot {
      width: 7px; height: 7px; border-radius: 50%;
      display: inline-block;
      background: var(--border);
      margin-right: 0.3rem;
      vertical-align: middle;
    }
    .sync-dot.connected { background: #22c55e; }

    /* ── Footer ── */
    footer {
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      font-size: 0.75rem;
      color: var(--muted);
      text-align: center;
    }
    footer a { color: var(--muted); }
  </style>
</head>
<body>
  <header>
    <div class="brief-title">☁ Morning Brief</div>
    <div class="brief-meta">
      <span>{{ date_display }}</span>
      <span>·</span>
      <span>~10 min read</span>
      <span>·</span>
      <span>{{ items|length }} items</span>
    </div>
  </header>

  {% if has_podcast %}
  <div class="podcast-player">
    <span class="podcast-label">Podcast</span>
    <audio controls preload="none" src="podcast.mp3"></audio>
  </div>
  {% endif %}

  <div class="sync-bar">
    <button onclick="markAllRead()">Mark all read</button>
    <button onclick="setupToken()"><span class="sync-dot" id="syncDot"></span>Sync</button>
    <span class="sync-status" id="syncStatus"></span>
  </div>

  <main>
    {% for source, articles in grouped.items() %}
    <details class="source-group" style="border-left-color: {{ source_colors[source] }}; background: linear-gradient(90deg, {{ source_colors_bg[source] }}, var(--surface));">
      <summary style="background: {{ source_colors_header[source] }};">
        <span class="source-dot" style="background: {{ source_colors[source] }}; box-shadow: 0 0 6px {{ source_colors_glow[source] }};"></span>
        {{ source }}
        <span class="article-count">{{ articles|length }} article{{ 's' if articles|length != 1 }}</span>
      </summary>
      <div class="source-group-body">
        {% for item in articles %}
        <article class="item" data-url="{{ item.url }}">
          <div class="item-content">
            <h2 class="item-headline">
              <a href="{{ item.url }}" target="_blank" rel="noopener">{{ item.title }}</a>
            </h2>
            <p class="one-liner">{{ item.one_liner }}</p>
            <div class="item-footer">
              {% if item.published_at %}
              <span class="score-pill">{{ item.published_at | ordinal_date }}</span>
              {% endif %}
              {% if item.score is defined %}
              <span class="score-pill">{{ "%.0f"|format(item.score) }}/10</span>
              {% endif %}
              {% if item.reason %}
              <span class="reason">{{ item.reason }}</span>
              {% endif %}
            </div>
          </div>
          <button class="mark-read-btn" onclick="toggleRead(this)">Mark read</button>
        </article>
        {% endfor %}
      </div>
    </details>
    {% endfor %}
  </main>

  <footer>
    <p>Generated {{ generated_at }} · <a href="https://github.com/koustubhg/morning-brief">morning-brief</a></p>
  </footer>

  <script>
    const STORAGE_KEY = 'morning-brief-read';
    const TOKEN_KEY = 'morning-brief-gh-token';
    const REPO = 'koustubh25/morning-brief';
    const FILE_PATH = 'output/read.json';

    // ── Local read state ──
    function getReadUrls() {
      try { return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]')); }
      catch { return new Set(); }
    }

    function saveReadUrls(urls) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...urls]));
    }

    // ── GitHub sync ──
    function getToken() { return localStorage.getItem(TOKEN_KEY); }

    function setSyncStatus(text, cls) {
      const el = document.getElementById('syncStatus');
      el.textContent = text;
      el.className = 'sync-status' + (cls ? ' ' + cls : '');
    }

    function updateSyncDot() {
      const dot = document.getElementById('syncDot');
      if (dot) dot.className = getToken() ? 'sync-dot connected' : 'sync-dot';
    }

    function setupToken() {
      const current = getToken();
      const action = current
        ? prompt('GitHub PAT is set. Enter new PAT, or type "clear" to remove:', '')
        : prompt('Enter a GitHub fine-grained PAT\n(scope: Contents read/write on ' + REPO + '):', '');
      if (action === null) return;
      if (action.toLowerCase() === 'clear') {
        localStorage.removeItem(TOKEN_KEY);
        setSyncStatus('Token cleared', '');
      } else if (action.trim()) {
        localStorage.setItem(TOKEN_KEY, action.trim());
        setSyncStatus('Token saved', 'ok');
        syncToGitHub();
      }
      updateSyncDot();
    }

    let syncTimeout = null;
    function debouncedSync() {
      clearTimeout(syncTimeout);
      syncTimeout = setTimeout(syncToGitHub, 800);
    }

    async function syncToGitHub() {
      const token = getToken();
      if (!token) return;

      setSyncStatus('Syncing…', '');
      try {
        // Get current file to obtain sha + merge remote URLs
        const getResp = await fetch(
          `https://api.github.com/repos/${REPO}/contents/${FILE_PATH}`,
          { headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'application/vnd.github.v3+json' } }
        );

        let sha = null;
        let remoteUrls = [];
        if (getResp.ok) {
          const data = await getResp.json();
          sha = data.sha;
          try { remoteUrls = JSON.parse(atob(data.content)); } catch {}
        } else if (getResp.status !== 404) {
          throw new Error(`GitHub GET ${getResp.status}`);
        }

        // Union-merge local + remote
        const merged = new Set([...getReadUrls(), ...remoteUrls]);
        saveReadUrls(merged);
        applyReadState();

        const content = btoa(JSON.stringify([...merged], null, 2));
        const body = {
          message: 'sync: update read.json',
          content: content,
        };
        if (sha) body.sha = sha;

        const putResp = await fetch(
          `https://api.github.com/repos/${REPO}/contents/${FILE_PATH}`,
          {
            method: 'PUT',
            headers: {
              'Authorization': `Bearer ${token}`,
              'Accept': 'application/vnd.github.v3+json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(body),
          }
        );

        if (!putResp.ok) {
          const err = await putResp.json();
          throw new Error(err.message || `PUT ${putResp.status}`);
        }

        setSyncStatus('Synced', 'ok');
      } catch (e) {
        console.error('Sync failed:', e);
        setSyncStatus('Sync failed', 'err');
      }
    }

    // ── UI actions ──
    function toggleRead(btn) {
      const item = btn.closest('.item');
      const url = item.dataset.url;
      const read = getReadUrls();
      if (read.has(url)) {
        read.delete(url);
        item.classList.remove('is-read');
        btn.textContent = 'Mark read';
      } else {
        read.add(url);
        item.classList.add('is-read');
        btn.textContent = 'Unmark';
      }
      saveReadUrls(read);
      updateCounts();
      debouncedSync();
    }

    function markAllRead() {
      const read = getReadUrls();
      document.querySelectorAll('.item').forEach(item => {
        read.add(item.dataset.url);
        item.classList.add('is-read');
        item.querySelector('.mark-read-btn').textContent = 'Unmark';
      });
      saveReadUrls(read);
      updateCounts();
      debouncedSync();
    }

    function updateCounts() {
      const read = getReadUrls();
      document.querySelectorAll('.source-group').forEach(group => {
        const items = group.querySelectorAll('.item');
        const total = items.length;
        const readCount = [...items].filter(i => read.has(i.dataset.url)).length;
        const badge = group.querySelector('.article-count');
        if (badge) badge.textContent = readCount > 0
          ? `${readCount}/${total} read`
          : `${total} article${total !== 1 ? 's' : ''}`;
      });
    }

    function applyReadState() {
      const read = getReadUrls();
      document.querySelectorAll('.item').forEach(item => {
        if (read.has(item.dataset.url)) {
          item.classList.add('is-read');
          item.querySelector('.mark-read-btn').textContent = 'Unmark';
        } else {
          item.classList.remove('is-read');
          item.querySelector('.mark-read-btn').textContent = 'Mark read';
        }
      });
      updateCounts();
    }

    // ── Init ──
    (function() {
      applyReadState();
      updateSyncDot();
    })();
  </script>
</body>
</html>
